msgid ""
"merge command needs either one or three arguments!\n"
"Got: %s"
msgstr ""
"Der merge-Befehl benötigt entweder einen oder drei Argumente!\n"
"Gegeben: %s"

#, c-format
msgid "Resizing array '%s' to %d"
msgstr "Verändere die Größe des Arrays '%s' auf %d"

#, c-format
